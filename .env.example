# Frontend / backend ports exposed on the host
FRONTEND_PORT=5173
BACKEND_PORT=8000

# Frontend runtime API target
VITE_API_BASE_URL=http://localhost:8000

# FastAPI app metadata
APP_NAME=Yuelin Official Site API
APP_ENV=development

# PostgreSQL container settings
POSTGRES_DB=yuelin_site
POSTGRES_USER=yuelin
POSTGRES_PASSWORD=yuelin_dev
DATABASE_URL=postgresql+psycopg://yuelin:yuelin_dev@db:5432/yuelin_site

# Keep this value as a JSON array string.
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
ALLOWED_HOSTS=["localhost","127.0.0.1","testserver"]
LOG_LEVEL=INFO
INQUIRY_RATE_LIMIT_MAX_REQUESTS=5
INQUIRY_RATE_LIMIT_WINDOW_SECONDS=300
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
ADMIN_SESSION_SECRET=development-admin-session-secret
ADMIN_SESSION_COOKIE_NAME=yuelin_admin_session
ADMIN_SESSION_TTL_HOURS=12
ADMIN_SESSION_COOKIE_SECURE=false
ADMIN_LOGIN_RATE_LIMIT_MAX_REQUESTS=8
ADMIN_LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
WEB_CONCURRENCY=1
